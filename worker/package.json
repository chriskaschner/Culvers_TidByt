{
  "name": "custard-calendar",
  "version": "1.0.0",
  "description": "Cloudflare Worker serving subscribable Culver's Flavor of the Day .ics calendars",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:browser": "playwright test --config playwright.config.mjs",
    "test:watch": "vitest",
    "bless:cones": "UPDATE_GOLDENS=1 vitest run --reporter=verbose 2>&1 | grep '^GOLDEN:'",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "sprites": "node ../tools/generate_sprites.mjs",
    "sprites:ai": "node ../tools/generate_ai_sprites.mjs"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^3.2.4",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
